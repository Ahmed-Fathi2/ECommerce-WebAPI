{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
      "WriteTo": [
        {
          "Name": "Console"
        },
        {
          "Name": "File",
          "Args": {
            "path": "Logs/log-.txt",
            "rollingInterval": "Day",
            "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"

          }
        },
        {
          "Name": "Seq",
          "Args": {
            "serverUrl": "http://localhost:5341"
          }
        }
      ],
      "Enrich": [

        "FromLogContext",
        "WithMachineName",
        "WithThreadId",
        "WithProcessId",
        "WithExceptionDetails"
      ],
    "Properties": {
      "ApplicationName": "ECommerce.API"
    }
    
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=EcommerceWebApi;Trusted_Connection=true;TrustServerCertificate=true"
  }

}
